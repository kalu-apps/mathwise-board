BOARD_RUNTIME_REDIS_COMMAND_RETRIES=1
BOARD_RUNTIME_REDIS_PUBLISH_RETRIES=2
BOARD_RUNTIME_REDIS_KEEPALIVE_MS=30000
BOARD_RUNTIME_REDIS_DISABLE_OFFLINE_QUEUE=0
