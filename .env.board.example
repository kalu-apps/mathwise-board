VITE_BOARD_MODE=realtime
VITE_WHITEBOARD_ONLY=1
VITE_FF_ZUSTAND_STORE=0
VITE_API_BASE_URL=https://api.your-domain.tld
VITE_PUBLIC_BASE_URL=https://board.your-domain.tld
VITE_WHITEBOARD_TEACHER_PASSWORD=change-me
CORS_ALLOWED_ORIGINS=https://board.your-domain.tld
AUTH_COOKIE_DOMAIN=.your-domain.tld
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_SECURE=1
BOARD_STORAGE_DRIVER=postgres
DATABASE_URL=postgresql://board_app:password@10.20.0.4:5432/board_prod?sslmode=require
WORKBOOK_ACCESS_LOG_RETENTION_DAYS=90
WORKBOOK_ACCESS_LOG_HASH_SALT=replace-with-random-salt
REDIS_URL=redis://default:password@10.20.0.5:6379
BOARD_RUNTIME_REDIS_REQUIRED=1
FF_NEST_API=0
FF_NEST_API_SHADOW=0
NEST_HOST=0.0.0.0
NEST_PORT=4180
NEST_API_BASE_URL=http://127.0.0.1:4180
NEST_LEGACY_BASE_URL=http://127.0.0.1:4173
NEST_PROXY_TIMEOUT_MS=3000
NEST_SHADOW_TIMEOUT_MS=1500
NEST_SHADOW_SAMPLE_RATE=1
NEST_WRITE_PROXY_TIMEOUT_MS=8000
NEST_OBJECT_VERSION_STRICT=0
NEST_IDEMPOTENCY_TTL_MS=300000
NEST_IDEMPOTENCY_MAX_RECORDS=20000
NEST_IDEMPOTENCY_BODY_FALLBACK=1
NEST_IDEMPOTENCY_SAMPLE_RATE=1
MEDIA_STUN_URLS=stun:stun.l.google.com:19302
MEDIA_TURN_URLS=turn:turn.board.your-domain.tld:3478?transport=udp,turns:turn.board.your-domain.tld:5349?transport=tcp
MEDIA_TURN_SECRET=replace-with-coturn-static-auth-secret
MEDIA_TURN_TTL_SECONDS=3600
MEDIA_LIVEKIT_WS_URL=wss://rtc.board.your-domain.tld
MEDIA_LIVEKIT_API_KEY=devkey
MEDIA_LIVEKIT_API_SECRET=replace-with-livekit-api-secret
MEDIA_LIVEKIT_TOKEN_TTL_SECONDS=3600
