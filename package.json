{
  "name": "math-realtime-board-service",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "VITE_DEV_HTTPS=1 vite",
    "dev:board": "vite --mode board --open /workbook",
    "build": "tsc -b && vite build",
    "build:board": "vite build --mode board",
    "lint": "eslint .",
    "verify": "npm run lint && npm run build:board",
    "preview": "vite preview",
    "start:board": "vite preview --mode board --host 0.0.0.0 --port ${PORT:-4173}",
    "backend:start": "node --import tsx backend/src/server.ts",
    "backend:start:board": "VITE_BOARD_MODE=realtime VITE_WHITEBOARD_ONLY=1 node --import tsx backend/src/server.ts"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "connect": "^3.7.0",
    "jspdf": "^4.1.0",
    "livekit-client": "^2.17.2",
    "mathjs": "^15.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.12.0",
    "redis": "^5.11.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/connect": "^3.4.38",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
